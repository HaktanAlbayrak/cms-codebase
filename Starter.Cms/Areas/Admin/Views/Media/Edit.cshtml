@using Starter.Cms.Domain
@model MediaEditModel
@{
    ViewData["Title"] = "Medya Düzenle";
    var languages = ViewBag.Languages as List<Language> ?? new();
    var asset = ViewBag.Asset as MediaAsset;
    string Size(long b) => b >= 1048576 ? $"{b / 1048576.0:0.#} MB" : $"{b / 1024.0:0.#} KB";
}

<partial name="_PageHelp" model="@("Bu dosyanın başlığını, alt metnini (görme engelliler ve SEO için <img alt>) ve açıklamasını her dilde ayrı yazabilirsiniz. Dosyanın kendisi değişmez; yalnızca bilgileri güncellenir.")" />

<form method="post" action="/Admin/Media/Edit" class="space-y-6">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="space-y-5 lg:col-span-2">
            <div class="rounded-2xl border border-slate-200 bg-white p-5">
                <div class="mb-4 flex gap-2 border-b border-slate-200">
                    @for (var i = 0; i < languages.Count; i++)
                    {
                        var lang = languages[i];
                        <button type="button" class="lang-tab -mb-px border-b-2 px-4 py-2 text-sm font-semibold @(i == 0 ? "border-brand text-brand" : "border-transparent text-slate-400")" data-lang="@lang.Code" onclick="showLang('@lang.Code', this)">
                            @lang.Name @(lang.IsDefault ? "★" : "")
                        </button>
                    }
                </div>

                @for (var i = 0; i < languages.Count; i++)
                {
                    var code = languages[i].Code;
                    <div class="lang-pane space-y-4 @(i == 0 ? "" : "hidden")" data-lang-pane="@code">
                        <div>
                            <label class="form-label">Başlık (@code)</label>
                            <input class="form-input" name="Title[@code]" value="@(Model.Title.TryGetValue(code, out var ti) ? ti : "")" />
                        </div>
                        <div>
                            <label class="form-label">Alt Metni / alt (@code)</label>
                            <input class="form-input" name="Alt[@code]" value="@(Model.Alt.TryGetValue(code, out var al) ? al : "")" placeholder="Görseli tanımlayan kısa metin" />
                        </div>
                        <div>
                            <label class="form-label">Açıklama (@code)</label>
                            <textarea class="form-input" name="Caption[@code]" rows="2">@(Model.Caption.TryGetValue(code, out var ca) ? ca : "")</textarea>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="space-y-5">
            <div class="rounded-2xl border border-slate-200 bg-white p-5">
                <h3 class="mb-3 text-sm font-bold text-ink">Önizleme</h3>
                @if (asset is not null)
                {
                    <div class="mb-3 flex items-center justify-center rounded-lg border border-slate-200 bg-slate-50 p-2">
                        @if (asset.Type == MediaType.Image)
                        {
                            <img src="@asset.Url" class="max-h-48 max-w-full object-contain" />
                        }
                        else if (asset.Type == MediaType.Video)
                        {
                            <video src="@asset.Url" class="max-h-48 max-w-full" controls></video>
                        }
                        else
                        {
                            <a href="@asset.Url" target="_blank" class="flex flex-col items-center gap-2 py-6 text-slate-400 hover:text-brand">
                                <i data-lucide="file-text" class="h-10 w-10"></i>
                                <span class="text-xs">Dosyayı aç</span>
                            </a>
                        }
                    </div>
                    <dl class="space-y-1 text-xs text-slate-500">
                        <div class="flex justify-between"><dt>Tür</dt><dd class="font-medium text-slate-700">@asset.Type</dd></div>
                        <div class="flex justify-between"><dt>Klasör</dt><dd class="font-medium text-slate-700">@asset.Folder</dd></div>
                        <div class="flex justify-between"><dt>Boyut</dt><dd class="font-medium text-slate-700">@Size(asset.Size)</dd></div>
                        @if (asset.Width is not null)
                        {
                            <div class="flex justify-between"><dt>Çözünürlük</dt><dd class="font-medium text-slate-700">@asset.Width×@asset.Height</dd></div>
                        }
                    </dl>
                    <div class="mt-3 flex items-center gap-2">
                        <input class="form-input !text-xs" value="@asset.Url" readonly onclick="this.select()" />
                        <button type="button" onclick="navigator.clipboard.writeText('@asset.Url')" class="btn-outline !px-2 !py-1.5"><i data-lucide="copy" class="h-4 w-4"></i></button>
                    </div>
                }
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
                <div>
                    <label class="form-label">Sıra</label>
                    <input class="form-input" name="SortOrder" type="number" value="@Model.SortOrder" />
                </div>
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") class="h-4 w-4 rounded border-slate-300" />
                    Aktif (kütüphanede/seçicide görünür)
                </label>
            </div>

            <div class="flex gap-2">
                <button type="submit" class="btn-brand flex-1">Kaydet</button>
                <a href="/Admin/Media" class="btn-outline">İptal</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function showLang(code, btn) {
            document.querySelectorAll('[data-lang-pane]').forEach(function (p) { p.classList.toggle('hidden', p.getAttribute('data-lang-pane') !== code); });
            document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('border-brand', 'text-brand'); t.classList.add('border-transparent', 'text-slate-400'); });
            btn.classList.add('border-brand', 'text-brand'); btn.classList.remove('border-transparent', 'text-slate-400');
        }
    </script>
}
