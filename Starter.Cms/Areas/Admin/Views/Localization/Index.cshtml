@{
    ViewData["Title"] = "Arayüz Metinleri";
    var languages = ViewBag.Languages as List<Language> ?? new();
    var keys = ViewBag.Keys as List<string> ?? new();
    var map = ViewBag.Map as Dictionary<string, Dictionary<string, string>> ?? new();
    string Val(string key, string lang) => map.TryGetValue(key, out var d) && d.TryGetValue(lang, out var v) ? v : "";
}

<partial name="_PageHelp" model="@("Menü, butonlar, footer gibi sabit arayüz metinleri. Her dil bir sekmedir; tüm diller tek 'Tümünü Kaydet' ile yazılır. Arama kutusu anahtarları filtreler.")" />

<form method="post" action="/Admin/Localization/Save">
    @Html.AntiForgeryToken()

    <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2">
            @for (var i = 0; i < languages.Count; i++)
            {
                var lang = languages[i];
                <button type="button" class="loc-tab rounded-lg border px-4 py-1.5 text-sm font-semibold @(i == 0 ? "border-brand bg-brand text-white" : "border-slate-200 bg-white text-slate-500")" data-lang="@lang.Code" onclick="showLocLang('@lang.Code', this)">@lang.Name</button>
            }
        </div>
        <input type="search" id="locSearch" class="form-input max-w-xs" placeholder="Anahtar ara… (ör. nav)" oninput="filterLoc(this.value)" />
    </div>

    @for (var i = 0; i < languages.Count; i++)
    {
        var code = languages[i].Code;
        <div class="loc-pane @(i == 0 ? "" : "hidden")" data-loc-pane="@code">
            <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
                        <tr><th class="w-1/3 px-5 py-3">Anahtar</th><th class="px-5 py-3">Değer (@code)</th></tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var key in keys)
                        {
                            <tr class="loc-row" data-key="@key">
                                <td class="px-5 py-2 font-mono text-xs text-slate-500">@key</td>
                                <td class="px-5 py-2">
                                    <input class="form-input" name="values[@key][@code]" value="@Val(key, code)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="sticky bottom-0 mt-5 flex justify-end border-t border-slate-200 bg-slate-100 py-4">
        <button type="submit" class="btn-brand">Tümünü Kaydet</button>
    </div>
</form>

@section Scripts {
    <script>
        function showLocLang(code, btn) {
            document.querySelectorAll('[data-loc-pane]').forEach(function (p) { p.classList.toggle('hidden', p.getAttribute('data-loc-pane') !== code); });
            document.querySelectorAll('.loc-tab').forEach(function (t) { t.classList.remove('border-brand', 'bg-brand', 'text-white'); t.classList.add('border-slate-200', 'bg-white', 'text-slate-500'); });
            btn.classList.add('border-brand', 'bg-brand', 'text-white'); btn.classList.remove('border-slate-200', 'bg-white', 'text-slate-500');
        }
        function filterLoc(q) {
            q = (q || '').toLowerCase();
            document.querySelectorAll('.loc-row').forEach(function (r) {
                r.style.display = r.getAttribute('data-key').toLowerCase().indexOf(q) > -1 ? '' : 'none';
            });
        }
    </script>
}
