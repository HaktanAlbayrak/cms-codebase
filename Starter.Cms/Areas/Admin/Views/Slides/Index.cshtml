@model List<Starter.Cms.Domain.Slide>
@{
    ViewData["Title"] = "Slider";
    var defaultCode = CultureContext.Default;
}

<partial name="_PageHelp" model="@("Ana sayfadaki hero slider. Her slaytın masaüstü görseli zorunludur; metinler her dil için ayrı sekmede girilir.")" />

<div class="mb-5 flex justify-end">
    <a href="/Admin/Slides/Edit" class="btn-brand"><i data-lucide="plus" class="h-4 w-4"></i>Yeni Slayt</a>
</div>

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    @foreach (var s in Model)
    {
        var t = s.Translations.FirstOrDefault(x => x.LanguageCode == defaultCode) ?? s.Translations.FirstOrDefault();
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
            <div class="relative h-36 bg-slate-100">
                @if (!string.IsNullOrWhiteSpace(s.ImageDesktop))
                {
                    <img src="@s.ImageDesktop" class="h-full w-full object-cover" />
                }
                @if (!s.IsActive)
                {
                    <span class="absolute left-2 top-2 rounded-full bg-slate-800/80 px-2 py-0.5 text-xs text-white">Pasif</span>
                }
            </div>
            <div class="p-4">
                <p class="truncate font-medium text-ink">@(t?.Title ?? "(başlıksız)")</p>
                <p class="truncate text-xs text-slate-400">@t?.Kicker</p>
                <div class="mt-3 flex justify-end gap-2">
                    <a href="/Admin/Slides/Edit/@s.Id" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-brand"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                    <form method="post" action="/Admin/Slides/Delete/@s.Id" onsubmit="return confirm('Bu slayt silinsin mi?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="rounded-lg p-2 text-slate-500 hover:bg-red-50 hover:text-red-600"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
    @if (Model.Count == 0)
    {
        <p class="text-sm text-slate-400">Henüz slayt yok.</p>
    }
</div>
