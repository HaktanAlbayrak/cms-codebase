@model HeaderFooterVm
@{
    var brand = Model.Branding;
    string Loc(string path) => CultureContext.LocalizedPath(path);
}
<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
        <a href="@Loc("/")" class="flex items-center gap-2">
            @* Logo zorunlu — kullanıcı yüklemezse varsayılan logo (BrandingService.DefaultLogo) gelir. *@
            <img src="@brand.LogoUrl" alt="@brand.CompanyName" class="h-9 w-auto sm:h-10" />
        </a>

        <nav class="hidden items-center gap-1 md:flex">
            @foreach (var item in Model.Menu)
            {
                <a href="@Loc(item.Url)" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand">@item.Label</a>
            }
        </nav>

        <div class="flex items-center gap-2">
            @if (Model.Languages.Count > 1)
            {
                <div class="flex items-center gap-1 rounded-lg border border-slate-200 p-0.5">
                    @foreach (var lang in Model.Languages)
                    {
                        var active = string.Equals(lang.Code, Model.Culture, StringComparison.OrdinalIgnoreCase);
                        <a href="@CultureContext.SwitchCulture(Context, lang.Code)"
                           class="rounded-md px-2 py-1 text-xs font-semibold uppercase transition @(active ? "bg-brand text-white" : "text-slate-500 hover:text-brand")">@lang.Code</a>
                    }
                </div>
            }
            <a href="@Loc("/contact")" class="btn-brand hidden sm:inline-flex">@Localizer["nav.cta"]</a>

            <button type="button" id="mobileMenuBtn" class="rounded-lg p-2 text-slate-600 md:hidden" aria-label="Menu">
                <i data-lucide="menu" class="h-6 w-6"></i>
            </button>
        </div>
    </div>

    <nav id="mobileMenu" class="hidden border-t border-slate-100 bg-white px-4 py-2 md:hidden">
        @foreach (var item in Model.Menu)
        {
            <a href="@Loc(item.Url)" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">@item.Label</a>
        }
    </nav>
</header>
<script>
    (function () {
        var btn = document.getElementById('mobileMenuBtn');
        var menu = document.getElementById('mobileMenu');
        if (btn && menu) btn.addEventListener('click', function () { menu.classList.toggle('hidden'); });
    })();
</script>
