@model IReadOnlyList<SlideVm>
@{
    string Loc(string url) => url.StartsWith("http") ? url : CultureContext.LocalizedPath(url);
    var isRtl = CultureContext.IsRtl(CultureContext.Current);
}
@if (Model.Count > 0)
{
    <section class="relative select-none overflow-hidden" data-slider aria-roledescription="carousel">
        @* Ray her zaman LTR akar (translateX geometrisi öngörülebilir olsun);
           slayt metni sayfa yönünü (RTL/LTR) korur. *@
        <div class="slider-track flex touch-pan-y" data-slider-track dir="ltr">
            @for (var i = 0; i < Model.Count; i++)
            {
                var s = Model[i];
                <div class="slider-slide w-full shrink-0" data-slide="@i" role="group" aria-roledescription="slide" aria-label="@(i + 1) / @Model.Count">
                    <div class="relative h-[60vh] min-h-[420px] w-full">
                        <img src="@s.ImageDesktop" alt="@s.Title" draggable="false" class="pointer-events-none absolute inset-0 h-full w-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-r from-ink/80 via-ink/50 to-transparent"></div>
                        <div class="relative mx-auto flex h-full max-w-7xl items-center px-4 sm:px-6">
                            <div class="max-w-xl text-white" dir="@(isRtl ? "rtl" : "ltr")">
                                @if (!string.IsNullOrWhiteSpace(s.Kicker))
                                {
                                    <span class="mb-3 inline-block rounded-full bg-brand/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide">@s.Kicker</span>
                                }
                                <h1 class="font-display text-3xl font-extrabold leading-tight sm:text-5xl">@s.Title</h1>
                                @if (!string.IsNullOrWhiteSpace(s.Subtitle))
                                {
                                    <p class="mt-4 text-base text-slate-200 sm:text-lg">@s.Subtitle</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.CtaText))
                                {
                                    <a href="@Loc(s.CtaUrl)" class="btn-brand mt-6">@s.CtaText</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.Count > 1)
        {
            @* Prev / Next okları *@
            <button type="button" data-slider-prev aria-label="@Localizer["common.previous"]"
                    class="absolute left-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/25 text-white backdrop-blur transition hover:bg-white/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-white sm:left-5">
                <i data-lucide="chevron-left" class="h-6 w-6"></i>
            </button>
            <button type="button" data-slider-next aria-label="@Localizer["common.next"]"
                    class="absolute right-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/25 text-white backdrop-blur transition hover:bg-white/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-white sm:right-5">
                <i data-lucide="chevron-right" class="h-6 w-6"></i>
            </button>

            @* Dot göstergeleri *@
            <div class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 gap-2">
                @for (var i = 0; i < Model.Count; i++)
                {
                    <button type="button" data-dot="@i" aria-label="@(i + 1)" class="h-2.5 rounded-full transition-all @(i == 0 ? "w-6 bg-white" : "w-2.5 bg-white/50")"></button>
                }
            </div>
        }
    </section>

    @if (Model.Count > 1)
    {
        <script>
            (function () {
                var root = document.querySelector('[data-slider]');
                if (!root) return;
                var track = root.querySelector('[data-slider-track]');
                var slides = root.querySelectorAll('[data-slide]');
                var dots = root.querySelectorAll('[data-dot]');
                var prevBtn = root.querySelector('[data-slider-prev]');
                var nextBtn = root.querySelector('[data-slider-next]');
                var count = slides.length;
                var cur = 0;
                var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                function setX(pct) { track.style.transform = 'translateX(' + pct + '%)'; }

                function update() {
                    setX(-cur * 100);
                    for (var i = 0; i < dots.length; i++) {
                        var on = i === cur;
                        dots[i].classList.toggle('bg-white', on);
                        dots[i].classList.toggle('w-6', on);
                        dots[i].classList.toggle('bg-white/50', !on);
                        dots[i].classList.toggle('w-2.5', !on);
                        dots[i].setAttribute('aria-current', on ? 'true' : 'false');
                    }
                }
                function go(n) { cur = (n + count) % count; update(); }

                if (nextBtn) nextBtn.addEventListener('click', function () { go(cur + 1); });
                if (prevBtn) prevBtn.addEventListener('click', function () { go(cur - 1); });
                for (var d = 0; d < dots.length; d++) {
                    (function (i) { dots[i].addEventListener('click', function () { go(i); }); })(d);
                }

                // Otomatik oynatma — sekme gizliyse / hover / sürükleme sırasında durur.
                var timer = null;
                function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }
                function startAuto() {
                    if (reduce || count < 2) return;
                    stopAuto();
                    timer = setInterval(function () { go(cur + 1); }, 6000);
                }
                root.addEventListener('mouseenter', stopAuto);
                root.addEventListener('mouseleave', startAuto);
                document.addEventListener('visibilitychange', function () {
                    if (document.hidden) stopAuto(); else startAuto();
                });

                // Sürükleme / kaydırma (Pointer Events → fare + dokunma tek kod).
                var dragging = false, startX = 0, delta = 0, w = 1;
                function down(e) {
                    dragging = true; startX = e.clientX; delta = 0;
                    w = root.getBoundingClientRect().width || 1;
                    track.classList.add('is-dragging');
                    stopAuto();
                    if (track.setPointerCapture) { try { track.setPointerCapture(e.pointerId); } catch (x) {} }
                }
                function move(e) {
                    if (!dragging) return;
                    delta = e.clientX - startX;
                    setX(-cur * 100 + (delta / w) * 100);
                }
                function up() {
                    if (!dragging) return;
                    dragging = false;
                    track.classList.remove('is-dragging');
                    var threshold = w * 0.15;
                    if (delta > threshold) go(cur - 1);
                    else if (delta < -threshold) go(cur + 1);
                    else update();
                    startAuto();
                }
                track.addEventListener('pointerdown', down);
                track.addEventListener('pointermove', move);
                track.addEventListener('pointerup', up);
                track.addEventListener('pointercancel', up);

                // Klavye erişilebilirliği
                root.setAttribute('tabindex', '0');
                root.addEventListener('keydown', function (e) {
                    if (e.key === 'ArrowLeft') go(cur - 1);
                    else if (e.key === 'ArrowRight') go(cur + 1);
                });

                update();
                startAuto();
            })();
        </script>
    }
}
