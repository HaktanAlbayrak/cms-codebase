@inject IBrandingService Branding
@{
    var brand = await Branding.GetAsync();
    var culture = CultureContext.Current;
    var isRtl = CultureContext.IsRtl(culture);

    var brandChannels = ColorUtil.ToRgbChannels(brand.ColorPrimary);
    var brandDarkChannels = ColorUtil.ToRgbChannels(brand.ColorPrimaryDark);
    var inkChannels = ColorUtil.ToRgbChannels(brand.ColorInk, "#0f172a");

    var pageTitle = ViewData["Title"] as string;
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle)
        ? Localizer["seo.siteTitle"].Value
        : $"{pageTitle} | {brand.CompanyName}";
    var metaDesc = ViewData["MetaDescription"] as string ?? Localizer["seo.description"].Value;
    var keywords = Localizer["seo.keywords"].Value;

    var scheme = Context.Request.Scheme;
    var host = Context.Request.Host.Value;
    var baseUrl = $"{scheme}://{host}";
    var canonical = $"{baseUrl}{Context.Request.Path}";
    var ogImage = string.IsNullOrWhiteSpace(brand.OgImageUrl)
        ? ""
        : (brand.OgImageUrl!.StartsWith("http") ? brand.OgImageUrl! : baseUrl + brand.OgImageUrl);
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@fullTitle</title>
    <meta name="description" content="@metaDesc" />
    <meta name="keywords" content="@keywords" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@canonical" />
    <link rel="icon" href="@brand.FaviconUrl" />

    @* hreflang alternate (her dil için karşı URL) + x-default *@
    @foreach (var lang in CultureContext.Supported)
    {
        <link rel="alternate" hreflang="@lang" href="@($"{baseUrl}{CultureContext.SwitchCulture(Context, lang)}")" />
    }
    <link rel="alternate" hreflang="x-default" href="@($"{baseUrl}{CultureContext.SwitchCulture(Context, CultureContext.Default)}")" />

    @* Open Graph *@
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@brand.CompanyName" />
    <meta property="og:title" content="@fullTitle" />
    <meta property="og:description" content="@metaDesc" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:locale" content="@culture" />
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }

    @* Twitter Card *@
    <meta name="twitter:card" content="@(string.IsNullOrEmpty(ogImage) ? "summary" : "summary_large_image")" />
    <meta name="twitter:title" content="@fullTitle" />
    <meta name="twitter:description" content="@metaDesc" />
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta name="twitter:image" content="@ogImage" />
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=Montserrat:wght@@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lightgallery@@2.7.2/css/lightgallery-bundle.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @* Marka renkleri DB'den (RGB kanal biçimi → bg-brand/90 gibi opacity modifier'ları çalışır) *@
    <style>
        :root {
            --brand: @brandChannels;
            --brand-dark: @brandDarkChannels;
            --ink: @inkChannels;
        }
    </style>

    @* JSON-LD yapısal veri (Organization + WebSite) *@
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Organization",
        "name": "@brand.CompanyName",
        "url": "@baseUrl",
        @if (!string.IsNullOrEmpty(ogImage)) { <text>"logo": "@ogImage",</text> }
        @if (!string.IsNullOrEmpty(brand.Phone)) { <text>"telephone": "@brand.Phone",</text> }
        "address": "@brand.Address"
    }
    </script>

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="min-h-screen bg-white text-ink antialiased">
    @await Component.InvokeAsync("Header")

    <main>
        @RenderBody()
    </main>

    @await Component.InvokeAsync("Footer")

    @{
        var waNumber = new string((brand.Whatsapp ?? "").Where(char.IsDigit).ToArray());
    }
    @if (!string.IsNullOrEmpty(waNumber))
    {
        <a href="https://wa.me/@waNumber" target="_blank" rel="noopener" class="wa-float" aria-label="@Localizer["whatsapp.tooltip"]">
            <span class="wa-ring" aria-hidden="true"></span>
            <span class="wa-ring wa-ring--delay" aria-hidden="true"></span>
            <span class="wa-tooltip">@Localizer["whatsapp.tooltip"]</span>
            <svg class="wa-icon" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                <path d="M16.04 4C9.95 4 5 8.95 5 15.04c0 1.95.51 3.86 1.48 5.54L4.9 27l6.6-1.73a11 11 0 0 0 4.54.98h.01c6.08 0 11.03-4.95 11.04-11.04A11 11 0 0 0 16.04 4Zm0 20.2h-.01a9.1 9.1 0 0 1-4.64-1.27l-.33-.2-3.92 1.03 1.05-3.82-.22-.34a9.13 9.13 0 0 1-1.4-4.86c0-5.06 4.12-9.18 9.19-9.18a9.13 9.13 0 0 1 9.18 9.19c0 5.06-4.12 9.18-9.18 9.18Zm5.04-6.88c-.28-.14-1.63-.8-1.89-.9-.25-.09-.43-.14-.62.14-.18.28-.71.9-.87 1.08-.16.18-.32.2-.6.07-.28-.14-1.17-.43-2.23-1.37-.82-.74-1.38-1.64-1.54-1.92-.16-.28-.02-.43.12-.57.13-.13.28-.32.42-.49.14-.16.18-.28.28-.46.09-.18.05-.35-.02-.49-.07-.14-.62-1.5-.85-2.05-.22-.54-.45-.47-.62-.48l-.53-.01c-.18 0-.46.07-.71.35-.25.28-.94.92-.94 2.24 0 1.32.96 2.6 1.1 2.78.14.18 1.9 2.9 4.6 4.06.64.28 1.14.44 1.53.57.64.2 1.23.17 1.69.1.51-.07 1.63-.66 1.86-1.31.23-.64.23-1.19.16-1.31-.07-.12-.25-.18-.53-.32Z"/>
            </svg>
        </a>
        <style>
            .wa-float{position:fixed;right:20px;bottom:20px;z-index:60;display:flex;align-items:center;justify-content:center;width:60px;height:60px;border-radius:9999px;background:linear-gradient(145deg,#2ee06c,#25d366 55%,#128c7e);color:#fff;box-shadow:0 10px 28px -6px rgba(37,211,102,.65),0 4px 10px rgba(0,0,0,.18);transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s ease;animation:wa-glow 2.4s ease-in-out infinite}
            .wa-float:hover{transform:scale(1.08)}
            .wa-float:active{transform:scale(.96)}
            .wa-icon{width:32px;height:32px;position:relative;z-index:2;filter:drop-shadow(0 1px 1px rgba(0,0,0,.2))}
            .wa-ring{position:absolute;inset:0;border-radius:9999px;background:#25d366;opacity:.55;z-index:1;animation:wa-ring 2.4s cubic-bezier(.2,.6,.3,1) infinite}
            .wa-ring--delay{animation-delay:1.2s}
            .wa-tooltip{position:absolute;right:74px;white-space:nowrap;background:#0b0b0d;color:#fff;font-size:13px;font-weight:600;padding:8px 14px;border-radius:8px;box-shadow:0 8px 24px -8px rgba(0,0,0,.5);opacity:0;transform:translateX(8px);pointer-events:none;transition:opacity .25s ease,transform .25s ease}
            .wa-tooltip::after{content:"";position:absolute;top:50%;right:-5px;margin-top:-5px;border:5px solid transparent;border-left-color:#0b0b0d}
            .wa-float:hover .wa-tooltip{opacity:1;transform:translateX(0)}
            [dir="rtl"] .wa-float{right:auto;left:20px}
            [dir="rtl"] .wa-tooltip{right:auto;left:74px;transform:translateX(-8px)}
            [dir="rtl"] .wa-tooltip::after{right:auto;left:-5px;border-left-color:transparent;border-right-color:#0b0b0d}
            [dir="rtl"] .wa-float:hover .wa-tooltip{transform:translateX(0)}
            @@keyframes wa-ring{0%{transform:scale(1);opacity:.55}70%{transform:scale(1.9);opacity:0}100%{transform:scale(1.9);opacity:0}}
            @@keyframes wa-glow{0%,100%{box-shadow:0 10px 28px -6px rgba(37,211,102,.55),0 4px 10px rgba(0,0,0,.18)}50%{box-shadow:0 12px 34px -4px rgba(37,211,102,.95),0 4px 10px rgba(0,0,0,.18)}}
            @@media (max-width:640px){.wa-float{width:54px;height:54px;right:16px;bottom:16px}[dir="rtl"] .wa-float{right:auto;left:16px}.wa-icon{width:28px;height:28px}}
            @@media (prefers-reduced-motion:reduce){.wa-float{animation:none}.wa-ring{animation:none;opacity:0}}
        </style>
    }

    <script src="https://unpkg.com/lucide@@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/lightgallery@@2.7.2/lightgallery.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/lightgallery@@2.7.2/plugins/thumbnail/lg-thumbnail.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/lightgallery@@2.7.2/plugins/zoom/lg-zoom.umd.min.js"></script>
    <script>
        if (window.lucide) lucide.createIcons();
        document.querySelectorAll('[data-lightgallery]').forEach(function (el) {
            window.lightGallery && lightGallery(el, { plugins: [window.lgThumbnail, window.lgZoom].filter(Boolean), speed: 400, download: false });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
