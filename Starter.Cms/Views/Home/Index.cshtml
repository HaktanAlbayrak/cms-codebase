@{
    ViewData["Title"] = null; // ana sayfa → seo.siteTitle kullanılır
}

@await Component.InvokeAsync("Slider")

<section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <div class="mb-12 text-center">
        <h2 class="font-display text-3xl font-extrabold text-ink sm:text-4xl">@Localizer["home.featuresTitle"]</h2>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
        @{
            var features = new (string Icon, string Title, string Text)[]
            {
                ("languages", Localizer["home.feature1Title"].Value, Localizer["home.feature1Text"].Value),
                ("layout-dashboard", Localizer["home.feature2Title"].Value, Localizer["home.feature2Text"].Value),
                ("mail-check", Localizer["home.feature3Title"].Value, Localizer["home.feature3Text"].Value),
            };
        }
        @foreach (var f in features)
        {
            <div class="rounded-2xl border border-slate-100 bg-white p-7 shadow-sm transition hover:shadow-md">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 text-brand">
                    <i data-lucide="@f.Icon" class="h-6 w-6"></i>
                </div>
                <h3 class="mb-2 text-lg font-bold text-ink">@f.Title</h3>
                <p class="text-sm leading-relaxed text-slate-500">@f.Text</p>
            </div>
        }
    </div>
</section>
