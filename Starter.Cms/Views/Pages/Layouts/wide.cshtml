@model PageVm

@if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
{
    <section class="relative h-[40vh] min-h-[300px] w-full">
        <img src="@Model.CoverImageUrl" alt="@Model.Title" class="absolute inset-0 h-full w-full object-cover" />
        <div class="absolute inset-0 bg-ink/60"></div>
        <div class="relative mx-auto flex h-full max-w-6xl items-end px-4 pb-10 sm:px-6">
            <h1 class="font-display text-4xl font-extrabold text-white">@Model.Title</h1>
        </div>
    </section>
}
else
{
    <section class="bg-ink py-16">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
            <h1 class="font-display text-4xl font-extrabold text-white">@Model.Title</h1>
        </div>
    </section>
}

<article class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    @if (!string.IsNullOrWhiteSpace(Model.Lead))
    {
        <p class="mb-8 text-xl text-slate-500" data-reveal>@Model.Lead</p>
    }
    <div class="prose prose-slate max-w-none lg:prose-lg" data-reveal>
        @Html.Raw(Model.Body)
    </div>
</article>
