@model List<AmtVinc.Cms.Domain.ContactMessage>
@{
    ViewData["Title"] = "Mesajlar";
}

<partial name="_PageHelp" model="@("İletişim formundan gelen mesajlar. Tıklayınca okundu işaretlenir. SMTP açıksa bu mesajlar e-posta olarak da iletilir.")" />

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
            <tr>
                <th class="px-5 py-3">Gönderen</th>
                <th class="px-5 py-3">Konu</th>
                <th class="px-5 py-3">Tarih</th>
                <th class="px-5 py-3 text-right">İşlem</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var m in Model)
            {
                <tr class="@(m.IsRead ? "" : "bg-amber-50/40")">
                    <td class="px-5 py-3">
                        <a href="/Admin/Messages/Detail/@m.Id" class="font-medium text-ink hover:text-brand">
                            @if (!m.IsRead)
                            {
                                <span class="mr-1 inline-block h-2 w-2 rounded-full bg-amber-500"></span>
                            }
                            @m.Name
                        </a>
                        <p class="text-xs text-slate-400" dir="ltr">@m.Email</p>
                    </td>
                    <td class="px-5 py-3 text-slate-600">@m.Subject</td>
                    <td class="px-5 py-3 text-slate-400">@m.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="px-5 py-3">
                        <div class="flex justify-end gap-2">
                            <a href="/Admin/Messages/Detail/@m.Id" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-brand"><i data-lucide="eye" class="h-4 w-4"></i></a>
                            <form method="post" action="/Admin/Messages/Delete/@m.Id" onsubmit="return confirm('Mesaj silinsin mi?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-lg p-2 text-slate-500 hover:bg-red-50 hover:text-red-600"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="4" class="px-5 py-8 text-center text-slate-400">Henüz mesaj yok.</td></tr>
            }
        </tbody>
    </table>
</div>
