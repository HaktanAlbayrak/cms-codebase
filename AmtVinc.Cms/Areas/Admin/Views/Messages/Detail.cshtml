@model AmtVinc.Cms.Domain.ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
}

<div class="mx-auto max-w-2xl">
    <a href="/Admin/Messages" class="mb-4 inline-flex items-center gap-1 text-sm text-slate-500 hover:text-brand"><i data-lucide="arrow-left" class="h-4 w-4"></i>Mesajlara dön</a>

    <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <div class="mb-5 flex items-start justify-between gap-4 border-b border-slate-100 pb-5">
            <div>
                <h2 class="text-lg font-bold text-ink">@Model.Subject</h2>
                <p class="text-sm text-slate-400">@Model.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
            </div>
            <a href="mailto:@Model.Email" class="btn-brand !text-xs">Yanıtla</a>
        </div>

        <dl class="space-y-3 text-sm">
            <div class="flex gap-3"><dt class="w-28 shrink-0 font-semibold text-slate-500">Ad Soyad</dt><dd class="text-ink">@Model.Name</dd></div>
            <div class="flex gap-3"><dt class="w-28 shrink-0 font-semibold text-slate-500">E-posta</dt><dd class="text-ink" dir="ltr">@Model.Email</dd></div>
            @if (!string.IsNullOrWhiteSpace(Model.Phone))
            {
                <div class="flex gap-3"><dt class="w-28 shrink-0 font-semibold text-slate-500">Telefon</dt><dd class="text-ink" dir="ltr">@Model.Phone</dd></div>
            }
            <div class="flex gap-3"><dt class="w-28 shrink-0 font-semibold text-slate-500">Mesaj</dt><dd class="whitespace-pre-line text-ink">@Model.Message</dd></div>
        </dl>
    </div>
</div>
