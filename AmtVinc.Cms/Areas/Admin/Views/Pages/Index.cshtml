@model List<AmtVinc.Cms.Domain.Page>
@{
    ViewData["Title"] = "Sayfalar";
    var defaultCode = CultureContext.Default;
}

<partial name="_PageHelp" model="@("Hakkımızda, gizlilik gibi içerik sayfaları. Her sayfa bir slug (URL adı) ile yayınlanır: /tr/about gibi. Düzenlemede her dil için ayrı sekme vardır.")" />

<div class="mb-5 flex justify-end">
    <a href="/Admin/Pages/Edit" class="btn-brand"><i data-lucide="plus" class="h-4 w-4"></i>Yeni Sayfa</a>
</div>

<div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
            <tr>
                <th class="px-5 py-3">Başlık</th>
                <th class="px-5 py-3">Slug (URL)</th>
                <th class="px-5 py-3">Şablon</th>
                <th class="px-5 py-3">Durum</th>
                <th class="px-5 py-3 text-right">İşlem</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var p in Model)
            {
                var t = p.Translations.FirstOrDefault(x => x.LanguageCode == defaultCode) ?? p.Translations.FirstOrDefault();
                <tr>
                    <td class="px-5 py-3 font-medium text-ink">@(t?.Title ?? p.Slug)</td>
                    <td class="px-5 py-3 text-slate-500">/@p.Slug</td>
                    <td class="px-5 py-3 text-slate-500">@p.LayoutKey</td>
                    <td class="px-5 py-3">
                        @if (p.IsActive)
                        {
                            <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Yayında</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500">Taslak</span>
                        }
                    </td>
                    <td class="px-5 py-3">
                        <div class="flex justify-end gap-2">
                            <a href="/Admin/Pages/Edit/@p.Id" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-brand"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                            <form method="post" action="/Admin/Pages/Delete/@p.Id" onsubmit="return confirm('Bu sayfa silinsin mi?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-lg p-2 text-slate-500 hover:bg-red-50 hover:text-red-600"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="px-5 py-8 text-center text-slate-400">Henüz sayfa yok.</td></tr>
            }
        </tbody>
    </table>
</div>
