@model string
@*  Sade Türkçe açıklama kutusu. Kullanım: <partial name="_PageHelp" model="Açıklama metni" />  *@
@if (!string.IsNullOrWhiteSpace(Model))
{
    <div class="mb-6 flex gap-3 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-800">
        <i data-lucide="info" class="mt-0.5 h-4 w-4 shrink-0"></i>
        <p>@Model</p>
    </div>
}
