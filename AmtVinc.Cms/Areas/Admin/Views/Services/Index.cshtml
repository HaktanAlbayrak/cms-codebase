@model List<AmtVinc.Cms.Domain.Service>
@{
    ViewData["Title"] = "Hizmetler";
    var defaultCode = CultureContext.Default;
}

<partial name="_PageHelp" model="@("Firmanızın sunduğu hizmetler (Vinç Kiralama, Platform Kiralama vb.). Ana sayfada ve /tr/hizmetler sayfasında listelenir. Her hizmet için ikon, görsel ve dil sekmeli içerik girilir.")" />

<div class="mb-5 flex justify-end">
    <a href="/Admin/Services/Edit" class="btn-brand"><i data-lucide="plus" class="h-4 w-4"></i>Yeni Hizmet</a>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
            <tr>
                <th class="px-5 py-3">İkon</th>
                <th class="px-5 py-3">Başlık</th>
                <th class="px-5 py-3">Slug (URL)</th>
                <th class="px-5 py-3">Durum</th>
                <th class="px-5 py-3 text-right">İşlem</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var s in Model)
            {
                var t = s.Translations.FirstOrDefault(x => x.LanguageCode == defaultCode) ?? s.Translations.FirstOrDefault();
                <tr>
                    <td class="px-5 py-3"><span class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand/10 text-brand"><i data-lucide="@s.Icon" class="h-5 w-5"></i></span></td>
                    <td class="px-5 py-3 font-medium text-ink">@(t?.Title ?? s.Slug)</td>
                    <td class="px-5 py-3 text-slate-500">/hizmet/@s.Slug</td>
                    <td class="px-5 py-3">
                        @if (s.IsActive)
                        {
                            <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Yayında</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500">Taslak</span>
                        }
                    </td>
                    <td class="px-5 py-3">
                        <div class="flex justify-end gap-2">
                            <a href="/Admin/Services/Edit/@s.Id" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-brand"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                            <form method="post" action="/Admin/Services/Delete/@s.Id" onsubmit="return confirm('Bu hizmet silinsin mi?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-lg p-2 text-slate-500 hover:bg-red-50 hover:text-red-600"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="px-5 py-8 text-center text-slate-400">Henüz hizmet yok.</td></tr>
            }
        </tbody>
    </table>
</div>
