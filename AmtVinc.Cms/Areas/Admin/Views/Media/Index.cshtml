@using AmtVinc.Cms.Domain
@model List<MediaAsset>
@{
    ViewData["Title"] = "Medya Kütüphanesi";
    var folders = ViewBag.Folders as List<string> ?? new();
    var selected = ViewBag.SelectedFolder as string;
    var selectedType = ViewBag.SelectedType as MediaType?;

    string Icon(MediaType t) => t switch
    {
        MediaType.Image => "image",
        MediaType.Video => "video",
        MediaType.Pdf => "file-text",
        MediaType.Audio => "music",
        MediaType.Document => "file",
        _ => "file"
    };
    string Size(long b) => b >= 1048576 ? $"{b / 1048576.0:0.#} MB" : $"{b / 1024.0:0.#} KB";
    var types = new (MediaType? Value, string Label)[]
    {
        (null, "Tümü"), (MediaType.Image, "Görseller"), (MediaType.Video, "Videolar"),
        (MediaType.Pdf, "PDF"), (MediaType.Document, "Belgeler"), (MediaType.Audio, "Ses")
    };
}

<partial name="_PageHelp" model="@("Sitede kullanılan tüm görsel, video, PDF ve belgeler burada toplanır ve veritabanından yönetilir. Bir dosyaya tıklayıp başlık/alt metni (SEO) düzenleyebilir, her dilde ayrı yazabilirsiniz. Bir kez yüklediğiniz dosyayı her alanda 'Medyadan Seç' ile yeniden kullanın.")" />

<div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
        @foreach (var t in types)
        {
            var active = selectedType == t.Value;
            var href = t.Value is null ? "/Admin/Media" : $"/Admin/Media?type={t.Value}";
            if (!string.IsNullOrEmpty(selected)) href += (href.Contains('?') ? "&" : "?") + "folder=" + selected;
            <a href="@href" class="rounded-lg px-3 py-1.5 text-sm @(active ? "bg-brand text-white" : "bg-white text-slate-600 border border-slate-200")">@t.Label</a>
        }
    </div>
    <form method="post" action="/Admin/Media/Upload" enctype="multipart/form-data" class="flex items-center gap-2">
        @Html.AntiForgeryToken()
        <input type="text" name="folder" value="@(string.IsNullOrEmpty(selected) ? "general" : selected)" class="form-input !w-28 !py-1.5 !text-xs" title="Klasör" />
        <input type="file" name="file" class="text-xs" required />
        <button type="submit" class="btn-brand !px-3 !py-1.5 !text-xs">Yükle</button>
    </form>
</div>

@if (folders.Count > 0)
{
    <div class="mb-5 flex flex-wrap gap-2 text-xs">
        <span class="py-1 text-slate-400">Klasörler:</span>
        <a href="/Admin/Media@(selectedType is null ? "" : $"?type={selectedType}")" class="rounded px-2 py-1 @(string.IsNullOrEmpty(selected) ? "bg-slate-200 text-slate-700" : "text-slate-500 hover:text-brand")">Hepsi</a>
        @foreach (var f in folders)
        {
            var href = $"/Admin/Media?folder={f}" + (selectedType is null ? "" : $"&type={selectedType}");
            <a href="@href" class="rounded px-2 py-1 @(selected == f ? "bg-slate-200 text-slate-700" : "text-slate-500 hover:text-brand")">@f</a>
        }
    </div>
}

<div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    @foreach (var m in Model)
    {
        <div class="group overflow-hidden rounded-xl border border-slate-200 bg-white @(m.IsActive ? "" : "opacity-50")">
            <a href="/Admin/Media/Edit/@m.Id" class="block">
                <div class="flex h-28 items-center justify-center bg-slate-50 p-1">
                    @if (m.Type == MediaType.Image)
                    {
                        <img src="@m.Url" class="max-h-full max-w-full object-contain" alt="@(m.Translations.FirstOrDefault()?.Alt)" />
                    }
                    else if (m.Type == MediaType.Video)
                    {
                        <video src="@m.Url" class="max-h-full max-w-full" muted></video>
                    }
                    else
                    {
                        <div class="flex flex-col items-center gap-1 text-slate-400">
                            <i data-lucide="@Icon(m.Type)" class="h-8 w-8"></i>
                            <span class="text-[10px] font-bold uppercase">@System.IO.Path.GetExtension(m.FileName).TrimStart('.')</span>
                        </div>
                    }
                </div>
            </a>
            <div class="p-2">
                <p class="truncate text-[11px] font-medium text-slate-600" title="@m.OriginalName">@m.OriginalName</p>
                <p class="text-[10px] text-slate-400">@Size(m.Size)@(m.Width is not null ? $" · {m.Width}×{m.Height}" : "")</p>
                <div class="mt-1 flex items-center justify-between">
                    <button type="button" onclick="navigator.clipboard.writeText('@m.Url')" class="text-[10px] text-slate-400 hover:text-brand">Kopyala</button>
                    <div class="flex items-center gap-2">
                        <a href="/Admin/Media/Edit/@m.Id" class="text-slate-400 hover:text-brand"><i data-lucide="pencil" class="h-3.5 w-3.5"></i></a>
                        <form method="post" action="/Admin/Media/Delete" onsubmit="return confirm('Dosya silinsin mi?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@m.Id" />
                            <button type="submit" class="text-slate-400 hover:text-red-600"><i data-lucide="trash-2" class="h-3.5 w-3.5"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (Model.Count == 0)
    {
        <p class="col-span-full py-8 text-center text-sm text-slate-400">Henüz dosya yok.</p>
    }
</div>
