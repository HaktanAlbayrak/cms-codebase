@model MachineCategoryEditModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Kategori" : "Kategori Düzenle";
    var languages = ViewBag.Languages as List<Language> ?? new();
}

<partial name="_PageHelp" model="@("Kategori adını her dil için ayrı sekmede girin. Slug, /tr/makineler sayfasındaki kategori bağlantısında kullanılır.")" />

<form method="post" action="/Admin/MachineCategories/Edit" class="space-y-6">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="space-y-5 lg:col-span-2">
            <div class="rounded-2xl border border-slate-200 bg-white p-5">
                <div class="mb-4 flex gap-2 border-b border-slate-200">
                    @for (var i = 0; i < languages.Count; i++)
                    {
                        var lang = languages[i];
                        <button type="button" class="lang-tab -mb-px border-b-2 px-4 py-2 text-sm font-semibold @(i == 0 ? "border-brand text-brand" : "border-transparent text-slate-400")" data-lang="@lang.Code" onclick="showLang('@lang.Code', this)">
                            @lang.Name @(lang.IsDefault ? "★" : "")
                        </button>
                    }
                </div>

                @for (var i = 0; i < languages.Count; i++)
                {
                    var lang = languages[i];
                    var code = lang.Code;
                    <div class="lang-pane @(i == 0 ? "" : "hidden")" data-lang-pane="@code">
                        <div>
                            <label class="form-label">Kategori Adı (@code)</label>
                            <input class="form-input" name="Name[@code]" value="@(Model.Name.TryGetValue(code, out var nm) ? nm : "")" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="space-y-5">
            <div class="rounded-2xl border border-slate-200 bg-white p-5">
                <h3 class="mb-4 text-sm font-bold text-ink">Ayarlar</h3>
                <div class="space-y-4">
                    <div>
                        <label class="form-label">Slug (URL adı)</label>
                        <input class="form-input" name="Slug" value="@Model.Slug" placeholder="makasli-platform" required />
                    </div>
                    <div>
                        <label class="form-label">Sıra</label>
                        <input class="form-input" name="SortOrder" type="number" value="@Model.SortOrder" />
                    </div>
                    <label class="flex items-center gap-2 text-sm">
                        <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") class="h-4 w-4 rounded border-slate-300" />
                        Aktif
                    </label>
                </div>
            </div>

            <div class="flex gap-2">
                <button type="submit" class="btn-brand flex-1">Kaydet</button>
                <a href="/Admin/MachineCategories" class="btn-outline">İptal</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function showLang(code, btn) {
            document.querySelectorAll('[data-lang-pane]').forEach(function (p) { p.classList.toggle('hidden', p.getAttribute('data-lang-pane') !== code); });
            document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('border-brand', 'text-brand'); t.classList.add('border-transparent', 'text-slate-400'); });
            btn.classList.add('border-brand', 'text-brand'); btn.classList.remove('border-transparent', 'text-slate-400');
        }
    </script>
}
