@model List<AmtVinc.Cms.Domain.MachineCategory>
@{
    ViewData["Title"] = "Makine Kategorileri";
    var defaultCode = CultureContext.Default;
}

<partial name="_PageHelp" model="@("Makine filosunu gruplamak için kategoriler (Manlift, Makaslı Platform, Sepetli Vinç vb.). Makine eklemeden önce en az bir kategori oluşturun. Kategori silinince içindeki makineler de silinir.")" />

<div class="mb-5 flex justify-end">
    <a href="/Admin/MachineCategories/Edit" class="btn-brand"><i data-lucide="plus" class="h-4 w-4"></i>Yeni Kategori</a>
</div>

<div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
            <tr>
                <th class="px-5 py-3">Kategori</th>
                <th class="px-5 py-3">Slug (URL)</th>
                <th class="px-5 py-3">Makine Sayısı</th>
                <th class="px-5 py-3">Durum</th>
                <th class="px-5 py-3 text-right">İşlem</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var c in Model)
            {
                var t = c.Translations.FirstOrDefault(x => x.LanguageCode == defaultCode) ?? c.Translations.FirstOrDefault();
                <tr>
                    <td class="px-5 py-3 font-medium text-ink">@(t?.Name ?? c.Slug)</td>
                    <td class="px-5 py-3 text-slate-500">@c.Slug</td>
                    <td class="px-5 py-3 text-slate-500">@c.Machines.Count</td>
                    <td class="px-5 py-3">
                        @if (c.IsActive)
                        {
                            <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Aktif</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500">Pasif</span>
                        }
                    </td>
                    <td class="px-5 py-3">
                        <div class="flex justify-end gap-2">
                            <a href="/Admin/MachineCategories/Edit/@c.Id" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-brand"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                            <form method="post" action="/Admin/MachineCategories/Delete/@c.Id" onsubmit="return confirm('Bu kategori ve içindeki tüm makineler silinsin mi?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-lg p-2 text-slate-500 hover:bg-red-50 hover:text-red-600"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="px-5 py-8 text-center text-slate-400">Henüz kategori yok.</td></tr>
            }
        </tbody>
    </table>
</div>
