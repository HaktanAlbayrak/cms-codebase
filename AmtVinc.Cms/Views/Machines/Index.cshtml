@model IReadOnlyList<MachineCategoryVm>
@{
    ViewData["Title"] = Localizer["machines.title"].Value;
    ViewData["MetaDescription"] = Localizer["machines.subtitle"].Value;
}

<section class="border-b border-slate-100 bg-slate-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6">
        <nav class="mb-4 text-sm text-slate-400">
            <a href="@CultureContext.LocalizedPath("/")" class="hover:text-brand">@Localizer["common.home"]</a>
            <span class="mx-1">/</span>
            <span class="text-slate-600">@Localizer["machines.title"]</span>
        </nav>
        <h1 class="font-display text-3xl font-extrabold text-ink sm:text-4xl">@Localizer["machines.title"]</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-500">@Localizer["machines.subtitle"]</p>
    </div>
</section>

<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    @if (Model.Count == 0)
    {
        <p class="text-center text-slate-400">@Localizer["common.emptyContent"]</p>
    }
    else
    {
        @* Kategori hızlı erişim çubuğu *@
        @if (Model.Count > 1)
        {
            <div class="mb-12 flex flex-wrap justify-center gap-2">
                @foreach (var c in Model)
                {
                    <a href="#kat-@c.Slug" class="rounded-full border border-slate-200 px-4 py-1.5 text-sm font-medium text-slate-600 transition hover:border-brand hover:text-brand">@c.Name</a>
                }
            </div>
        }

        @foreach (var c in Model)
        {
            <section id="kat-@c.Slug" class="mb-16 scroll-mt-24">
                <div class="mb-6 flex items-center gap-3">
                    <span class="h-6 w-1.5 rounded-full bg-brand"></span>
                    <h2 class="font-display text-2xl font-extrabold text-ink">@c.Name</h2>
                </div>
                <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var m in c.Machines)
                    {
                        <partial name="_MachineCard" model="m" />
                    }
                </div>
            </section>
        }
    }
</div>
