@model IReadOnlyList<SlideVm>
@{
    string Loc(string url) => url.StartsWith("http") ? url : CultureContext.LocalizedPath(url);
}
@if (Model.Count > 0)
{
    <section class="relative" data-slider>
        <div class="slider-track relative overflow-hidden">
            @for (var i = 0; i < Model.Count; i++)
            {
                var s = Model[i];
                <div class="slider-slide @(i == 0 ? "block" : "hidden")" data-slide="@i">
                    <div class="relative h-[60vh] min-h-[420px] w-full">
                        <img src="@s.ImageDesktop" alt="@s.Title" class="absolute inset-0 h-full w-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-r from-ink/80 via-ink/50 to-transparent"></div>
                        <div class="relative mx-auto flex h-full max-w-7xl items-center px-4 sm:px-6">
                            <div class="max-w-xl text-white">
                                @if (!string.IsNullOrWhiteSpace(s.Kicker))
                                {
                                    <span class="mb-3 inline-block rounded-full bg-brand/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide">@s.Kicker</span>
                                }
                                <h1 class="font-display text-3xl font-extrabold leading-tight sm:text-5xl">@s.Title</h1>
                                @if (!string.IsNullOrWhiteSpace(s.Subtitle))
                                {
                                    <p class="mt-4 text-base text-slate-200 sm:text-lg">@s.Subtitle</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.CtaText))
                                {
                                    <a href="@Loc(s.CtaUrl)" class="btn-brand mt-6">@s.CtaText</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.Count > 1)
        {
            <div class="absolute bottom-5 left-1/2 flex -translate-x-1/2 gap-2">
                @for (var i = 0; i < Model.Count; i++)
                {
                    <button type="button" data-dot="@i" class="h-2.5 w-2.5 rounded-full bg-white/50 transition @(i == 0 ? "bg-white" : "")"></button>
                }
            </div>
        }
    </section>

    @if (Model.Count > 1)
    {
        <script>
            (function () {
                var root = document.querySelector('[data-slider]');
                if (!root) return;
                var slides = root.querySelectorAll('[data-slide]');
                var dots = root.querySelectorAll('[data-dot]');
                var cur = 0;
                function show(n) {
                    slides.forEach(function (s, i) { s.classList.toggle('hidden', i !== n); s.classList.toggle('block', i === n); });
                    dots.forEach(function (d, i) { d.classList.toggle('bg-white', i === n); });
                    cur = n;
                }
                dots.forEach(function (d, i) { d.addEventListener('click', function () { show(i); }); });
                setInterval(function () { show((cur + 1) % slides.length); }, 6000);
            })();
        </script>
    }
}
